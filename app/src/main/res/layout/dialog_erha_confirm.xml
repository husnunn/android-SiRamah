<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/_16sdp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/surface_container_lowest"
        app:cardCornerRadius="@dimen/_24sdp"
        app:cardElevation="@dimen/_12sdp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/_8sdp"
                android:background="@drawable/bg_erha_dialog_gradient_strip" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="false"
                android:maxHeight="420dp"
                android:overScrollMode="ifContentScrolls">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/_24sdp"
                    android:paddingTop="@dimen/_24sdp"
                    android:paddingBottom="@dimen/_8sdp">

                    <FrameLayout
                        android:id="@+id/flConfirmIconContainer"
                        android:layout_width="@dimen/_64sdp"
                        android:layout_height="@dimen/_64sdp"
                        android:layout_gravity="center_horizontal">

                        <ImageView
                            android:id="@+id/ivConfirmHeaderIcon"
                            android:layout_width="@dimen/_36sdp"
                            android:layout_height="@dimen/_36sdp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_erha_icon_circle_soft"
                            android:contentDescription="@null"
                            android:padding="@dimen/_8sdp"
                            android:src="@drawable/ic_erha_popup_confirm"
                            app:tint="@color/primary" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvConfirmTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_16sdp"
                        android:fontFamily="sans-serif-black"
                        android:gravity="center"
                        android:textColor="@color/on_surface"
                        android:textSize="@dimen/_18ssp"
                        tools:text="Konfirmasi Presensi?" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardConfirmDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_16sdp"
                        app:cardBackgroundColor="@color/surface_container_low"
                        app:cardCornerRadius="@dimen/_16sdp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:id="@+id/llConfirmRows"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/_16sdp" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvConfirmDisclaimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_16sdp"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.25"
                        android:textColor="@color/secondary"
                        android:textSize="@dimen/_9ssp"
                        android:visibility="gone"
                        tools:text="Data presensi akan langsung tercatat…"
                        tools:visibility="visible" />
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/_24sdp"
                android:paddingBottom="@dimen/_24sdp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmPositive"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/_48sdp"
                    android:text="@string/erha_popup_confirm_primary"
                    android:textAllCaps="false"
                    android:textSize="@dimen/_14ssp"
                    app:cornerRadius="@dimen/_12sdp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmNegative"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_8sdp"
                    android:minHeight="@dimen/_48sdp"
                    android:text="@string/erha_popup_confirm_cancel"
                    android:textAllCaps="false"
                    android:textSize="@dimen/_14ssp"
                    app:cornerRadius="@dimen/_12sdp"
                    app:strokeColor="@color/outline_variant" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
